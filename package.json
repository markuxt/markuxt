{
  "name": "@markuxt/markuxt",
  "version": "0.1.27",
  "description": "A Markdown-first academic portal framework for laboratories, research groups, and knowledge communities, powered by Nuxt.",
  "author": "hnrobert",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./nuxt.config.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markuxt/markuxt.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "nuxt.config.ts",
    "app.config.ts",
    "app.config.d.ts",
    "src/"
  ],
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "pack:local": "pnpm pack --pack-destination /tmp/markuxt-dist",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@icon-park/vue-next": "^1.4.2",
    "@nuxt/content": "^2.13.4",
    "@nuxtjs/i18n": "^10.4.0",
    "hastscript": "^9.0.1",
    "katex": "0.16.47",
    "mermaid": "11.15.0",
    "nuxt": "^3.15.1",
    "rehype-katex": "7.0.1",
    "remark-math": "6.0.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "typescript": "^5.7.3",
    "vue-tsc": "^3.2.4"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@nuxt/schema": "^4.4.5"
      }
    },
    "allowedDeprecatedVersions": {
      "glob": "10.5.0",
      "prebuild-install": "7.1.3",
      "unplugin-vue-router": "0.19.2"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "b",
      "better-sqlite3",
      "d",
      "e",
      "esbuild",
      "i",
      "l",
      "s",
      "u",
      "vue-demi"
    ]
  }
}
